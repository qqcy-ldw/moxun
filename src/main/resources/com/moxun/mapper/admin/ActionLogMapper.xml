<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.moxun.mapper.admin.ActionLogMapper">

    <resultMap id="BaseResultMap" type="com.moxun.Pojo.Entity.UserActionLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="login_status" property="loginStatus"/>
        <result column="fail_reason" property="failReason"/>
        <result column="action_type" property="actionType"/>
        <result column="action_desc" property="actionDesc"/>
        <result column="resource_type" property="resourceType"/>
        <result column="resource_id" property="resourceId"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="user_agent" property="userAgent"/>
        <result column="request_url" property="requestUrl"/>
        <result column="request_method" property="requestMethod"/>
        <result column="request_params" property="requestParams"/>
        <result column="response_code" property="responseCode"/>
        <result column="response_result" property="responseResult"/>
        <result column="duration" property="duration"/>
        <result column="request_id" property="requestId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.moxun.Pojo.Entity.UserActionLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_action_logs (
            user_id,
            login_status,
            fail_reason,
            action_type,
            action_desc,
            resource_type,
            resource_id,
            ip_address,
            user_agent,
            request_url,
            request_method,
            request_params,
            response_code,
            response_result,
            duration,
            request_id
        ) VALUES (
            #{userId},
            #{loginStatus},
            #{failReason},
            #{actionType},
            #{actionDesc},
            #{resourceType},
            #{resourceId},
            #{ipAddress},
            #{userAgent},
            #{requestUrl},
            #{requestMethod},
            #{requestParams},
            #{responseCode},
            #{responseResult},
            #{duration},
            #{requestId}
        )
    </insert>

    <!-- PageHelper 自动处理分页，无需手动写 LIMIT OFFSET -->
    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT * FROM user_action_logs
        <where>
            <if test="dto.userId != null">
                AND user_id = #{dto.userId}
            </if>
            <if test="dto.actionType != null and dto.actionType != ''">
                AND action_type = #{dto.actionType}
            </if>
            <if test="dto.resourceType != null and dto.resourceType != ''">
                AND resource_type = #{dto.resourceType}
            </if>
            <if test="dto.startTime != null">
                AND create_time &gt;= #{dto.startTime}
            </if>
            <if test="dto.endTime != null">
                AND create_time &lt;= #{dto.endTime}
            </if>
            <if test="dto.ipAddress != null and dto.ipAddress != ''">
                AND ip_address LIKE CONCAT('%', #{dto.ipAddress}, '%')
            </if>
            <if test="dto.requestId != null and dto.requestId != ''">
                AND request_id = #{dto.requestId}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM user_action_logs WHERE id = #{id}
    </select>

    <select id="selectRecentByUserId" resultMap="BaseResultMap">
        SELECT * FROM user_action_logs
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

    <delete id="deleteBeforeTime">
        DELETE FROM user_action_logs WHERE create_time &lt; #{time}
    </delete>

</mapper>
